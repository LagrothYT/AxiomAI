{
    "model": {
        "n_layers": 4,
        "n_heads": 4,
        "d_model": 256,
        "d_ff": 1024,
        "max_seq_len": 512,
        "vocab_size": 4096
    },
    "training": {
        "batch_size": 8,
        "lr": 0.0003,
        "epochs": 5,
        "grad_accum_steps": 4,
        "dropout": 0.1,
        "early_stopping_patience": 3,
        "val_split": 0.1,
        "grad_clip": 1.0,
        "weight_decay": 0.1,
        "train_samples": 1,
        "train_sample_len": 32,
        "train_sample_prompt": ""
    },
    "generation": {
        "max_new_tokens": 256,
        "temperature": 0.8,
        "top_p": 0.9,
        "eos_token": "<EOS>"
    },
    "chat": {
        "user_prefix": "[USER]",
        "gpt_prefix": "[GPT]",
        "human_role": "[HUMAN]",
        "gpt_role": "[GPT]"
    },
    "paths": {
        "data_dir": "data",
        "processed_data_dir": "data/processed",
        "checkpoint_dir": "model/checkpoint",
        "tokenizer_dir": "tokenizer",
        "best_model_path": "model/best/best.pt"
    }
}