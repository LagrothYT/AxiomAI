{
    "model": {
        "n_layers": 4,
        "n_heads": 4,
        "d_model": 32,
        "d_ff": 128,
        "max_seq_len": 128,
        "vocab_size": 4096
    },
    "training": {
        "batch_size": 4,
        "lr": 0.0003,
        "epochs": 1500,
        "grad_accum_steps": 8,
        "dropout": 0.1,
        "early_stopping_patience": 0,
        "val_split": 0.1,
        "grad_clip": 1.0,
        "weight_decay": 0.01,
        "early_stopping_enabled": false,
        "min_lr_ratio": 0.3,
        "warmup_steps": 100,
        "seed": 42
    },
    "generation": {
        "max_new_tokens": 128,
        "temperature": 0.8,
        "top_p": 0.9,
        "eos_token": "<EOS>"
    },
    "chat": {
        "user_prefix": "[USER]",
        "gpt_prefix": "[GPT]",
        "human_role": "[HUMAN]",
        "gpt_role": "[GPT]"
    },
    "paths": {
        "data_dir": "data",
        "processed_data_dir": "data/processed",
        "checkpoint_dir": "model/checkpoint",
        "tokenizer_dir": "tokenizer",
        "best_model_path": "model/best/best.pt"
    }
}